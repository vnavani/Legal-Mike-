# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key
# Also referenced as the public URL in workflow helpers
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# ─── Cloudflare R2 (S3-compatible storage) ───────────────────────────────────
# See backend/src/lib/storage.ts for details
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=mike

# ─── Document download token signing ────────────────────────────────────────
# Falls back to SUPABASE_SECRET_KEY if not set
DOWNLOAD_SIGNING_SECRET=your-download-signing-secret

# ─── LLM Provider Keys ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-api-key

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
